{
  "name": "pdi",
  "version": "1.0.0",
  "description": "Landing page institucional",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "sass": "sass --watch scss:css",
    "dev": "concurrently \"npm run server\" \"npm run sass\" \"npm run browser-sync\"",
    "browser-sync": "browser-sync start --config bs-config.js",
    "build": "sass scss:css --style=compressed",
    "start": "npm run dev",
    "server": "node server.js",
    "server:dev": "concurrently \"npm run server\" \"npm run sass\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "browser-sync": "^2.29.3",
    "concurrently": "^8.2.2",
    "sass": "^1.69.5"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "resend": "^6.12.0"
  }
}
