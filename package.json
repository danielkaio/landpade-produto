{
  "name": "pdi",
  "version": "1.0.0",
  "description": "Landing page institucional",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "sass": "sass --watch scss:css",
    "dev": "concurrently \"npm run sass\" \"npm run browser-sync\"",
    "browser-sync": "browser-sync start --server . --files '*.html, css/*.css, js/*.js'",
    "build": "sass scss:css --style=compressed",
    "start": "npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "sass": "^1.69.5",
    "browser-sync": "^2.29.3",
    "concurrently": "^8.2.2"
  }
}
